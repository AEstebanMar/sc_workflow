export cluster_annotation="" 		                                	 		#-------# Cluster annotation file. If empty (""), cell annotation file will be used to dynamically assign cell types.
export cell_annotation="$exp_data_folder/canon.tsv" 					 		#-------# Path to marker-cell type file
export imported_counts="$exp_data_folder/counts_matrices"				 		#-------# Imported counts directory containing cellranger output files. If not empty, daemon 2 will load these files instead of output of daemon 1.
export meta_file=""							 									#-------# Path to imported metadata file. If left empty, it will be assumed to be located in "$imported_counts/meta.tsv"
export SingleR_ref=""								 							#-------# Name of reference to use. If empty (""), no SingleR annotation will be performed. WARNING: It looks like this no longer works when launching small datasets in parallel. Not sure still, but bear it in mind.
export ref_filter="" 													 		#-------# Filter to apply to reference dataset. Write it naturally, program will handle parsing. Leave empty ("") to disable filtering.
export ref_label="" 											 				#-------# Column of reference metadata to use in annotation. For celldex references: "label.main", "label.fine", "label.ont". Dataset-specific otherwise.
export ref_de_method=""													 		#-------# Method to use for marker calculation in single-cell reference. If not a single-cell reference (e.g. celldex reference), leave empty ("").
export ref_n=25															 		#-------# Top N reference markers to consider in annotation. Higher values provide a more accurate annotation, but increase noise and computational time. Will not be used if ref_de_method is empty.
export fine_tune=TRUE													 		#-------# Controls SingleR fine tuning. We recommend leaving it to TRUE. FALSE will accelerate analysis but at great cost to annotation results. Useful in development or in dataset exploration, but not in proper analyses.
export aggr_ref=FALSE 													 		#-------# Controls SingleR reference aggregation. We recommend leaving it to FALSE. TRUE will accelerate analysis but at some cost to annotation results. Useful in development or in dataset exploration, but might result in lower-quality annotation.
export save_trained_object=FALSE									    		#-------# Whether or not trained SingleR object should be saved to disk. Will be saved in output/trained_SingleR.R
export load_trained_object=FALSE									    		#-------# Whether or not trained SingleR object should be loaded from disk. Will be loaded from output/trained_SingleR.R
export target_genes="" 								 							#-------# List of semicolon-separated target genes ("target_1;target_2").

######  REFERENCE CREATION VARIABLES #######

export ref_to_process="scRNAseq"												#-------# Database from where data will be consulted to build and locally save reference. Values: "celldex" and "scRNAseq" for reference packages, or path to locally downloaded reference.
export ref_name=""        														#-------# Reference name, required field in scRNAseq and celldex databases. Otherwise, arbitrary name you wish to give the reference, relevant in showcase report.
export ref_version=""     														#-------#    Reference version to use. In scRNAseq and celldex databases, this is a required field. Leave empty ("") otherwise.
export ref_output_path="" 														#-------# Path where reference will be saved.
export label_to_trim=""	  														#-------# When creating a SingleR reference, some labels often come with NA values that need to be trimmed.

##################################
######## QUALITY CONTROL #########
##################################

export preproc_filter=TRUE                            					 		#-------# TRUE for using only detected cell-associated barcodes, FALSE for using all detected barcodes
export preproc_init_min_cells=1                       					 		#-------# If a feature appears in a number of cells smaller than this, it will not be included in the Seurat object. Recommended for raw data: 3
export preproc_init_min_feats=1                       					 		#-------# Cells with a number of features smaller than this will not be used when creating the Seurat object. Recommended for raw data: 200
export preproc_qc_min_feats=500                       					 		#-------# Cells with a number of features smaller than this will be filtered out in the QC step.
export preproc_max_percent_mt=5                       					 		#-------# Discard cell if MT percentage is higher than this
export preproc_norm_method=LogNormalize               					 		#-------# Seurat normalization method: LogNormalize, CLR, RC
export preproc_scale_factor=10000                     					 		#-------# Seurat scale factor for cell-level normalization
export preproc_select_hvgs=2000                       					 		#-------# Number of HVG to be selected (feature selection)
export preproc_pca_n_dims=10                          					 		#-------# Number of PC to use for clustering / UMAP / tSNE
export preproc_resolution=0.33                         					 		#-------# Granularity of the clustering (higher values -> greater number of clusters)
export preproc_pca_n_cells=500                        					 		#-------# Heatmap plots the 'extreme' cells on both ends of the spectrum -> dramatically speeds plotting for large datasets
export p_adj_cutoff=5e-3							  					 		#-------# Adjusted p-value cutoff for marker selection when annotating cell types
export min_cells_per_sample=500											 		#-------# Samples with a number of cells smaller than this will be discarded.
export min_counts=10															#-------# Min counts threshold to consider a gene as expressed in quality control.

##################################
### SUBSETTING AND INTEGRATION ###
##################################

export filter_dataset="Age > 3 & Tissue == 'Brain'"   					 		#-------# Filter to apply when importing counts. Program will handle parsing. Leave empty ("") to apply no filter. Separate different filters with logical operators. Only supports applying the same operator.
export subset_by="colA;colB"                            					 	#-------# Columns by which to subset data in certain steps of the analysis. Will not reduce dataset, this is a consideration to individually study effects of experimental factors.
export int_method="RPCA"							  					 		#-------# Method to use for integration. Values: "CCA", "RPCA", "Harmony", "FastMNN", "scVI"
export extra_columns="" 							  					#-------# Additional columns to represent in certain plots in the report. Will not be used in analysis, only to provide additional sample information when exploring results. Leave empty ("") to disable. Example: "age;region"
export k_weight=90 									  					 		#-------# Number of neighbors to consider when weighting anchors. Used in integration.

#############################################
##### DEG and marker analysis variables #####
#############################################

export generate_targets="
		generate_targets.rb -e $exp_design -t 'target_name>factorA:control_feature,treatment_feature_1/treatment_feature_2;factorB:control_Feature,treatment_feature' -f factorB=value1 -o $TARGETS_FOLDER
	"																			#-------# Commands to generate target files. Whole string will be interpreted by parser. Include a call to generate_targets.rb in string for every target you wish to generate.
													  					 		#-------# To specify factors to compare, input them next to factor column like so (column:factorA,factorB). You can also group two values by separating them with the "/" symbol. For example, column:factorA,factorB/factorC will compare factor A with factors B and C jointly as the same group.
													  					 		#-------# You can specify multiple comparisons by separating them with ";". If empty, no DEG analysis will be performed.
													  					 		#-------# Separate a comparison from its name with the ">" symbol. See config_default for an example.
export min_avg_log2fc=1.5 							  					 		#-------# Min log2fc cutoff for significant DEGs
export DEG_p_val_cutoff=1e-5 						  					 		#-------# Min p_val cutoff for significant DEGs
export min_cell_proportion=0.1 							  				 		#-------# Min threshold for percentage of cells expressing gene in either of the DEG analysis groups.
export simple_DEG_pct=FALSE # By default, Seurat's marker calculation function includes a cell proportion filter, but it only checks if any of the two groups is above this threshold. `simple_DEG_pct` corrects this behaviour. its default value, FALSE, triggers a check that removes DEGs where _any_ of the two groups is below the threshold.
export top_N=10 																#-------# Top DEGs to represent in certain plots. We recommend leaving this set to Inf, but it can be useful in test datasets.
export min_counts=10 													 		#-------# Min counts threshold to consider a gene is expressed in a cell.

##################################
######## RUN CONFIGURATION #######
##################################

export reduce=FALSE 													 		#-------# If TRUE, dataset seurat object will be randomly downsampled to 3000 cells. Useful in testing.
export multi_mem='192'													 		#-------# GB to pass to cellranger multi call. Just the number, not the unit (ALWAYS GB)
export multi_cpu='52'													 		#-------# Cores to require in cellranger multi.
export multi_time='2-00:00:00'											 		#-------# Time to request in cellranger multi.
export constraint='sd'													 		#-------# AutoFlow constrait.
#export int_cpu=128														 		#-------# CPUs to use in integrative analysis
#export int_mem="600gb"												     		#-------# Memory to use in integrative analysis
export launch_login=FALSE                                                		#-------# TRUE: use batch execution. FALSE: send to slurm.
export verbose=FALSE													 		#-------# Set to TRUE to set "verbose" argument of base Seurat functions to TRUE. Only recommended for debugging, as it bloats the error logs with progress bars. However, it is also the only way to monitor how many clusters have been found by the FindClusters function.
export sketch=TRUE 													 	 		#-------# A boolean. Set to FALSE to disable data sketching.
export sketch_pct=25 													 		#-------# Percentage of cells to select in sketching.
export sketch_method="LeverageScore" 									 		#-------# Method for sketching scores calculation. If empty ("")
export force_ncells="" 													 		#-------# Force sketching function to select this many cells per sample. Leave empty ("") to disable forcing.
export sigfig=3 														 		#-------# Significant figures by which to round off certain results.
